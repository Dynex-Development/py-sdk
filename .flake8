[flake8]
max-line-length = 120
extend-ignore = E203, W503
per-file-ignores =
    # __init__.py files export modules, so F401 is acceptable
    */__init__.py:F401
    # proto files are auto-generated - ignore all errors
    dynex/proto/*.py:E,F,W
    # Long docstrings are acceptable in these files
    dynex/sampler.py:E501
    dynex/grpc_client.py:E501
    dynex/dynex_circuit.py:E501
    dynex/models.py:E501
    dynex/api.py:E501
