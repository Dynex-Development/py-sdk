# Dynex SDK Configuration
# ============================
# Copy this file to .env and fill with your actual credentials
# NEVER commit .env to git!

# Required: API key for network access (e.g., sk_test_W8zhoBqhR26mHgshynCSGZ-tSG17k0iIYERmUcQMdJs)
DYNEX_SDK_KEY=your_sdk_key_here

# gRPC endpoint
DYNEX_GRPC_ENDPOINT=quantum-router-engine-grpc.hz.dynex.co:3000

# Optional: Integration tests control
# If credentials are present, integration tests run automatically
# Set to 'false' to explicitly disable them
# RUN_INTEGRATION_TESTS=false
